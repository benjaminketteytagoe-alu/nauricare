// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
enum Role {
  PATIENT
  PROVIDER
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  PROVIDER_REGISTER
  PROVIDER_VERIFY
  PROVIDER_SUSPEND
  RECORD_ACCESS
  ADMIN_SETTINGS_UPDATE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PrescriptionStatus {
  PENDING
  ROUTED
  FULFILLED
}

enum UserNotificationType {
  MENTION_POST
  MENTION_COMMENT
  FOLLOW
}

// --- Core Models ---
model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  phoneNumber    String?   @unique
  passwordHash   String
  dateOfBirth    DateTime?
  role           Role      @default(PATIENT)
  privacyConsent Boolean   @default(false)
  handle            String?   @unique
  isVerified        Boolean   @default(false)
  isEmailVerified   Boolean   @default(false)
  // Required by the NextAuth PrismaAdapter contract (Magic Link). Distinct from
  // isEmailVerified above — that field drives our own app logic; this one only
  // exists so the adapter's updateUser() call doesn't fail on unknown fields.
  emailVerified     DateTime?
  avatarUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  patientProfile      PatientProfile?
  practitionerProfile PractitionerProfile?
  symptomChecks       SymptomCheck[]
  notifications       Notification[]
  providerProfile     ProviderProfile?
  auditLogs           AuditLog[]
  resetTokens         ResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  accounts                Account[]
  sessions                Session[]

  // Social graph — rows where I'm the follower / the one being followed
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")

  // Messaging Relations
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  // Prescription relations
  patientPrescriptions  Prescription[] @relation("PatientPrescriptions")
  providerPrescriptions Prescription[] @relation("ProviderPrescriptions")

  // In-app notification relations
  receivedNotifications UserNotification[] @relation("NotificationRecipient")
  sentNotifications     UserNotification[] @relation("NotificationActor")

  // Community Relations
  communityPosts    CommunityPost[]    @relation("PostAuthor")
  communityComments CommunityComment[] @relation("CommentAuthor")
  communityLikes    CommunityLike[]
  communityStories  CommunityStory[]   @relation("StoryAuthor")
}

model PatientProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  country          String
  menstrualCycle   String?
  emergencyContact String?

  healthGoals String[] @default([])

  // Relations
  cycleLogs     CycleLog[]
  habitLogs     HabitLog[]
  healthRecords HealthRecord[] @relation("PatientHealthRecords")
  appointments  Appointment[]  @relation("PatientAppointments")
}

model PractitionerProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   String?
  clinicName String
  specialty  String // e.g., "Endocrinologist", "Gynecologist"
  bio        String?
  isVerified Boolean @default(false) // Admin approval flag

  appointments  Appointment[]  @relation("DoctorAppointments")
  healthRecords HealthRecord[] @relation("ProviderHealthRecords")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Healthcare Feature Models ---
model SymptomCheck {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   Json
  riskLevel String
  createdAt DateTime @default(now())
}

model Appointment {
  id String @id @default(cuid())

  patientProfileId String
  patient          PatientProfile @relation("PatientAppointments", fields: [patientProfileId], references: [id], onDelete: Cascade)

  practitionerProfileId String
  practitioner          PractitionerProfile @relation("DoctorAppointments", fields: [practitionerProfileId], references: [id], onDelete: Cascade)

  // Scheduling details
  startTime DateTime
  endTime   DateTime
  status    String   @default("PENDING")

  // Telehealth & clinical data
  meetingLink String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prescriptions Prescription[]

  @@index([patientProfileId])
  @@index([practitionerProfileId])
  @@index([startTime])
}

model HealthRecord {
  id String @id @default(cuid())

  patientProfileId String
  patient          PatientProfile @relation("PatientHealthRecords", fields: [patientProfileId], references: [id], onDelete: Cascade)

  practitionerProfileId String
  practitioner          PractitionerProfile @relation("ProviderHealthRecords", fields: [practitionerProfileId], references: [id], onDelete: Cascade)

  // Record Details
  type        String
  documentUrl String?
  notes       String?
  content     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientProfileId])
  @@index([practitionerProfileId])
}

// --- Communication Models ---
model Message {
  id         String @id @default(cuid())
  senderId   String
  sender     User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  status      NotificationStatus @default(PENDING)
  message     String
  scheduledAt DateTime?
  createdAt   DateTime           @default(now())
}

// --- Platform Resources ---
model Pharmacy {
  id           String         @id @default(cuid())
  name         String
  address      String
  contactEmail String?
  tags         String[]
  createdAt    DateTime       @default(now())

  prescriptions Prescription[]
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String
  authorId    String?
  tags        String[]
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model CycleLog {
  id               String         @id @default(cuid())
  patientProfileId String
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)

  startDate   DateTime
  endDate     DateTime?
  cycleLength Int?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientProfileId])
}

model HabitLog {
  id               String         @id @default(cuid())
  patientProfileId String
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)

  habitId   Int
  date      DateTime @db.Date
  completed Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientProfileId, habitId, date])
  @@index([patientProfileId, date])
}

model ProviderProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  specialty          String
  licenseNumber      String             @unique
  verificationStatus VerificationStatus @default(PENDING)

  verifiedAt   DateTime?
  verifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── NextAuth PrismaAdapter models (Magic Link / EmailProvider) ───────────────
// Standard shape required by @next-auth/prisma-adapter. Account/Session exist
// only to satisfy the adapter contract — sessions still use the JWT strategy.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Token itself is stored hashed (see hashToken() in next-auth/core/lib/utils) —
// the raw token only ever exists in the emailed magic link.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  actorId   String
  targetId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime    @default(now())

  // Relations
  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

// --- Community Models ---

model CommunityPost {
  id        String     @id @default(cuid())
  content   String
  mediaUrl  String?
  mediaType MediaType?
  authorId  String
  author    User       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Self-referential repost relation
  repostOfId String?
  repostOf   CommunityPost?  @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts    CommunityPost[] @relation("Reposts")

  comments      CommunityComment[]
  likes         CommunityLike[]
  notifications UserNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt])
}

model CommunityComment {
  id       String        @id @default(cuid())
  content  String
  postId   String
  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User          @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  notifications UserNotification[]

  createdAt DateTime @default(now())

  @@index([postId])
}

model CommunityLike {
  id     String        @id @default(cuid())
  postId String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Prescription {
  id             String             @id @default(cuid())
  medicationName String
  dosage         String
  instructions   String?
  status         PrescriptionStatus @default(PENDING)

  patientId  String
  patient    User   @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   User   @relation("ProviderPrescriptions", fields: [providerId], references: [id], onDelete: Cascade)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  pharmacyId String?
  pharmacy   Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([providerId])
  @@index([pharmacyId])
}

model UserNotification {
  id          String               @id @default(cuid())
  recipientId String
  recipient   User                 @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User                 @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  type        UserNotificationType
  postId      String?
  post        CommunityPost?       @relation(fields: [postId], references: [id], onDelete: SetNull)
  commentId   String?
  comment     CommunityComment?    @relation(fields: [commentId], references: [id], onDelete: SetNull)
  isRead      Boolean              @default(false)
  createdAt   DateTime             @default(now())

  @@index([recipientId])
  @@index([recipientId, isRead])
}

model CommunityStory {
  id        String  @id @default(cuid())
  content   String?
  imageUrl  String?
  authorId  String
  author    User    @relation("StoryAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([authorId])
  @@index([expiresAt])
}
