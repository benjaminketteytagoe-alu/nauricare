// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
enum Role {
  PATIENT
  PRACTITIONER
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// --- Core Models ---
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(PATIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  patientProfile      PatientProfile?
  practitionerProfile PractitionerProfile?
  symptomChecks       SymptomCheck[]
  appointments        Appointment[]        @relation("PatientAppointments")
}

model PatientProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth    DateTime?
  country        String
  menstrualCycle String?  
}

model PractitionerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty      String
  bio            String?
  clinicName     String?
  location       String
  isVerified     Boolean  @default(false)
  price          String?
  
  appointments   Appointment[] @relation("DoctorAppointments")
}

// --- Healthcare Feature Models ---
model SymptomCheck {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   Json     // Stores the questionnaire responses
  riskLevel String   // e.g., "High", "Low", "Medium"
  createdAt DateTime @default(now())
}

model Appointment {
  id             String            @id @default(cuid())
  patientId      String
  patient        User              @relation("PatientAppointments", fields: [patientId], references: [id])
  practitionerId String
  practitioner   PractitionerProfile @relation("DoctorAppointments", fields: [practitionerId], references: [id])
  
  date           DateTime
  type           String            // "Virtual" or "In-Person"
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?           // Post-consult notes
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

// --- Platform Resources ---
model Pharmacy {
  id          String   @id @default(cuid())
  name        String
  location    String
  contactInfo String?
  tags        String[] // Array of tags e.g. ["PCOS Meds", "Supplements"]
  createdAt   DateTime @default(now())
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String
  authorId    String?
  tags        String[]
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g., "LOGIN", "APPOINTMENT_BOOKED"
  details   Json?
  createdAt DateTime @default(now())
}
